{
  "swagger": "2.0",
  "info": {
    "title": "Standalone LOA Stub API",
    "version": "1.0",
    "description": "Stub API that simulates a third-party system returning LOA PDF documents."
  },
  "paths": {
    "/lookup": {
      "post": {
        "summary": "Lookup LOA document for an employee",
        "consumes": ["application/json"],
        "produces": [
          "application/pdf",
          "application/json"
        ],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["id"],
              "properties": {
                "id": {
                  "type": "string",
                  "example": "1001",
                  "description": "Employee ID for which the LOA document is requested"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "LOA document returned as PDF",
            "schema": {
              "type": "file"
            },
            "headers": {
              "Content-Disposition": {
                "type": "string",
                "description": "Attachment filename for the LOA PDF",
                "example": "attachment; filename=LOA_1001.pdf"
              },
              "X-Employee-Id": {
                "type": "string",
                "example": "1001"
              },
              "X-Document-Type": {
                "type": "string",
                "example": "LOA"
              }
            }
          },
          "400": {
            "description": "Invalid request payload",
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "example": "error"
                },
                "message": {
                  "type": "string",
                  "example": "Field 'id' is required"
                }
              }
            }
          },
          "404": {
            "description": "Document not found",
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "example": "error"
                },
                "message": {
                  "type": "string",
                  "example": "Document not found"
                }
              }
            }
          }
        }
      }
    }
  }
}